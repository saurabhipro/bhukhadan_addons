<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_cba_workflow_tree" model="ir.ui.view">
        <field name="name">cba.workflow.tree</field>
        <field name="model">cba.workflow</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code" optional="show"/>
                <field name="model_id" optional="show"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'active'"/>
                <field name="node_count"/>
                <field name="transition_count"/>
                <field name="is_default" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_cba_workflow_form" model="ir.ui.view">
        <field name="name">cba.workflow.form</field>
        <field name="model">cba.workflow</field>
        <field name="arch" type="xml">
            <form string="Workflow Definition">
                <header>
                    <button name="action_set_active" string="Activate"
                            type="object" class="btn-primary"
                            invisible="state == 'active'"/>
                    <button name="action_set_draft" string="Set Draft"
                            type="object"
                            invisible="state != 'active'"/>
                    <button name="action_sync_from_bpmn" string="Sync from BPMN"
                            type="object" class="btn-secondary"
                            invisible="not bpmn_xml"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,active,archived"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Workflow name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="model_id"/>
                            <field name="model_name" invisible="1"/>
                            <field name="is_default"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="node_count"/>
                            <field name="transition_count"/>
                            <field name="description"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Define Workflow (BPMN)" class="o_cba_bpmn_designer_tab">
                            <group colspan="2" col="1" class="o_cba_bpmn_designer_group">
                                <field name="bpmn_xml" widget="cba_bpmn_modeler" nolabel="1"/>
                            </group>
                        </page>
                        <page string="Nodes / States">
                            <field name="node_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="bpmn_id"/>
                                    <field name="node_type"/>
                                    <field name="join_mode"/>
                                    <field name="show_in_workflow"/>
                                    <field name="requires_photo"/>
                                    <field name="python_action" optional="hide"/>
                                    <field name="action_args" optional="hide"/>
                                </list>
                                <form string="Workflow Node">
                                    <group>
                                        <group>
                                            <field name="name"/>
                                            <field name="bpmn_id"/>
                                            <field name="node_type"/>
                                            <field name="sequence"/>
                                            <field name="join_mode"/>
                                        </group>
                                        <group>
                                            <field name="show_in_workflow"/>
                                            <field name="requires_photo"/>
                                            <field name="group_ids" widget="many2many_tags"/>
                                            <field name="user_ids" widget="many2many_tags"/>
                                        </group>
                                    </group>
                                    <group string="Actions">
                                        <field name="python_action" widget="text"/>
                                        <field name="action_args"/>
                                    </group>
                                    <field name="description"/>
                                </form>
                            </field>
                        </page>
                        <page string="Transfers">
                            <field name="transition_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="from_node_id"/>
                                    <field name="to_node_id"/>
                                    <field name="condition"/>
                                    <field name="trans_type" widget="radio"/>
                                    <field name="group_ids" widget="many2many_tags" optional="hide"/>
                                    <field name="user_ids" widget="many2many_tags" optional="hide"/>
                                </list>
                                <form string="Transition">
                                    <group>
                                        <group>
                                            <field name="name"/>
                                            <field name="from_node_id"/>
                                            <field name="to_node_id"/>
                                            <field name="condition"/>
                                            <field name="trans_type" widget="radio" options="{'horizontal': true}"/>
                                        </group>
                                        <group>
                                            <field name="bpmn_flow_id"/>
                                            <field name="stroke_color" widget="color"/>
                                            <field name="stroke_width"/>
                                            <field name="group_ids" widget="many2many_tags"/>
                                            <field name="user_ids" widget="many2many_tags"/>
                                        </group>
                                    </group>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_cba_workflow_node_popup" model="ir.ui.view">
        <field name="name">cba.workflow.node.popup</field>
        <field name="model">cba.workflow.node</field>
        <field name="arch" type="xml">
            <form string="Open: Activity">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="show_in_workflow"/>
                            <field name="calendar_notify"/>
                            <field name="trans_type"/>
                            <field name="workflow_id" invisible="1"/>
                            <field name="bpmn_id" invisible="1"/>
                            <field name="node_type" invisible="1"/>
                        </group>
                        <group>
                            <field name="join_mode"/>
                            <field name="no_decision"/>
                            <field name="fill_color" widget="color"/>
                            <field name="stroke_color" widget="color"/>
                            <field name="stroke_width"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Actions">
                            <group>
                                <group string="Approve">
                                    <field name="audit_type" widget="radio"/>
                                    <field name="group_ids" widget="many2many_tags"/>
                                    <field name="user_ids" widget="many2many_tags"/>
                                    <field name="flow_role"/>
                                </group>
                                <group string="Todo Task" invisible="trans_type != 'todo'">
                                    <field name="module_name"/>
                                    <field name="task_model_id"/>
                                    <field name="real_id"/>
                                    <field name="view_id"/>
                                    <field name="menu_id"/>
                                    <field name="task_condition"/>
                                    <field name="action_context"/>
                                </group>
                                <group string="Event Detection" invisible="trans_type != 'event'">
                                    <field name="module_name"/>
                                    <field name="task_model_id"/>
                                    <field name="task_condition"/>
                                    <field name="real_id"/>
                                </group>
                            </group>
                            <group string="Auto Process" invisible="trans_type != 'auto'">
                                <field name="python_action" widget="text"/>
                                <field name="action_args"/>
                            </group>
                            <group string="Need Note" invisible="trans_type != 'need_note'">
                                <field name="description" placeholder="Instructions shown when this step requires a note…"/>
                            </group>
                            <group>
                                <field name="requires_photo"/>
                            </group>
                        </page>
                        <page string="Fields">
                            <field name="target_model_id" invisible="1"/>
                            <group>
                                <button name="action_load_model_fields" type="object"
                                        string="Load Model Fields" class="btn-secondary"/>
                                <button name="action_all_to_readonly" type="object"
                                        string="All to Readonly" class="btn-secondary"/>
                            </group>
                            <field name="field_line_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="field_id"/>
                                    <field name="readonly"/>
                                    <field name="is_required"/>
                                    <field name="invisible"/>
                                    <field name="group_ids" widget="many2many_tags"/>
                                    <field name="user_ids" widget="many2many_tags"/>
                                    <field name="target_model_id" column_invisible="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <button string="Save" special="save" class="btn-primary"/>
                    <button string="Discard" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_cba_workflow_transition_popup" model="ir.ui.view">
        <field name="name">cba.workflow.transition.popup</field>
        <field name="model">cba.workflow.transition</field>
        <field name="arch" type="xml">
            <form string="Open: Transition">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="condition"/>
                            <field name="from_node_id"/>
                            <field name="to_node_id"/>
                            <field name="bpmn_flow_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="workflow_id"/>
                            <field name="stroke_color" widget="color"/>
                            <field name="stroke_width" string="Width of Stroke"/>
                            <field name="is_reverse"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Actions">
                            <group>
                                <field name="trans_type" string="Action Type"/>
                                <field name="group_ids" widget="many2many_tags"/>
                                <field name="user_ids" widget="many2many_tags"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <button string="Save" special="save" class="btn-primary"/>
                    <button string="Discard" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_cba_workflow_search" model="ir.ui.view">
        <field name="name">cba.workflow.search</field>
        <field name="model">cba.workflow</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="model_id"/>
                <filter string="Active" name="active_state" domain="[('state', '=', 'active')]"/>
                <filter string="Draft" name="draft_state" domain="[('state', '=', 'draft')]"/>
            </search>
        </field>
    </record>

    <record id="action_cba_workflow" model="ir.actions.act_window">
        <field name="name">Workflow Designer</field>
        <field name="res_model">cba.workflow</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a BPMN workflow
            </p>
            <p>
                Design states and transitions visually, sync nodes from the diagram,
                and attach the workflow to CBA cases.
            </p>
        </field>
    </record>
</odoo>
