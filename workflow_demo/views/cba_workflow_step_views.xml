<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_cba_workflow_step_tree" model="ir.ui.view">
        <field name="name">cba.workflow.step.tree</field>
        <field name="model">cba.workflow.step</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="bpmn_id"/>
                <field name="step_type"/>
                <field name="lane"/>
                <field name="parent_id"/>
                <field name="requires_photo"/>
            </list>
        </field>
    </record>

    <record id="view_cba_workflow_step_form" model="ir.ui.view">
        <field name="name">cba.workflow.step.form</field>
        <field name="model">cba.workflow.step</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="bpmn_id"/>
                            <field name="sequence"/>
                            <field name="step_type"/>
                            <field name="lane"/>
                            <field name="parent_id"/>
                        </group>
                        <group>
                            <field name="requires_photo"/>
                            <field name="next_step_id"/>
                            <field name="next_step_yes_id"/>
                            <field name="next_step_no_id"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <field name="description"/>
                    <notebook>
                        <page string="Sub-Steps">
                            <field name="child_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="bpmn_id"/>
                                    <field name="requires_photo"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_cba_workflow_step" model="ir.actions.act_window">
        <field name="name">CBA Workflow Steps</field>
        <field name="res_model">cba.workflow.step</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('parent_id', '=', False)]</field>
    </record>
</odoo>
