<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="module_category_cba" model="ir.module.category">
        <field name="name">Coal Bearing Act</field>
        <field name="sequence">50</field>
    </record>
    <record id="group_cba_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="module_category_cba"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>
    <record id="group_cba_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="module_category_cba"/>
        <field name="implied_ids" eval="[(4, ref('group_cba_user'))]"/>
    </record>

    <record id="base.user_admin" model="res.users">
        <field name="groups_id" eval="[(4, ref('group_cba_manager'))]"/>
    </record>
</odoo>
