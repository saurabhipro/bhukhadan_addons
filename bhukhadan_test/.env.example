# Odoo base URL (use 127.0.0.1 — not localhost — Odoo often listens IPv4-only)
BHUKHADAN_BASE_URL=http://127.0.0.1:8069

# Must be a mobile already registered on a res.users record in Odoo
BHUKHADAN_TEST_MOBILE=9876543210

# OTP fallback only — used when request_otp does NOT return details.
# Patwari / auto-fill responses already include the OTP; that value is preferred.
# BHUKHADAN_TEST_OTP=1234

# Optional: skip mutating survey create/update tests
# BHUKHADAN_SKIP_MUTATIONS=1
