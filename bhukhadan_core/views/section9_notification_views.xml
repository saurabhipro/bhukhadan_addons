<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_section9_notification_tree" model="ir.ui.view">
        <field name="name">bhu.section9.notification.tree</field>
        <field name="model">bhu.section9.notification</field>
        <field name="arch" type="xml">
            <list string="Section 9 Notifications" default_order="create_date desc">
                <field name="name"/>
                <field name="project_id"/>
                <field name="village_id"/>
                <field name="declaration_number"/>
                <field name="declaration_date"/>
                <field name="state"/>
                <field name="pending_with"/>
            </list>
        </field>
    </record>

    <record id="view_section9_notification_form" model="ir.ui.view">
        <field name="name">bhu.section9.notification.form</field>
        <field name="model">bhu.section9.notification</field>
        <field name="arch" type="xml">
            <form string="Section 9 Notification">
                <header>
                    <button name="action_submit" type="object" string="Submit" class="btn-primary" invisible="state != 'draft' or not can_sdm_edit"/>
                    <button name="action_approve" type="object" string="Approve" class="btn-success" invisible="state != 'submitted' or not can_collector_edit"/>
                    <button name="action_send_back" type="object" string="Send Back" class="btn-warning" invisible="state != 'submitted' or not can_collector_edit"/>
                    <button name="action_print_section9" type="object" string="Print Section 9" class="btn-secondary"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,send_back"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="project_id" readonly="is_approved_readonly"/>
                            <field name="village_id" readonly="is_approved_readonly"/>
                            <field name="pending_with" readonly="1"/>
                        </group>
                        <group>
                            <field name="declaration_number" readonly="is_approved_readonly"/>
                            <field name="declaration_date" readonly="is_approved_readonly"/>
                            <field name="gazette_publication_date" readonly="is_approved_readonly"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Details">
                            <field name="notification_summary" readonly="is_approved_readonly"/>
                            <field name="remarks" readonly="is_approved_readonly"/>
                        </page>
                        <page string="Workflow Files">
                            <group>
                                <group>
                                    <field name="sdm_signed_filename" invisible="1"/>
                                    <field name="sdm_signed_file" filename="sdm_signed_filename" readonly="state == 'approved'"/>
                                </group>
                                <group>
                                    <field name="collector_signed_filename" invisible="1"/>
                                    <field name="collector_signed_file" filename="collector_signed_filename" readonly="state == 'approved'"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_section9_notification" model="ir.actions.act_window">
        <field name="name">(Sec 9) Section 9 Notifications</field>
        <field name="res_model">bhu.section9.notification</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_section9_notification_tree"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create Section 9 declarations and move them through the Coal Act workflow.</p>
        </field>
    </record>
</odoo>
