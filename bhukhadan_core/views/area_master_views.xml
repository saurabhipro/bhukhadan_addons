<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_bhukhadan_area_master_tree" model="ir.ui.view">
            <field name="name">bhukhadan.area.master.tree</field>
            <field name="model">bhukhadan.area.master</field>
            <field name="type">list</field>
            <field name="arch" type="xml">
                <list string="Areas / क्षेत्र" decoration-muted="active == False">
                    <field name="name"/>
                    <field name="active" widget="boolean_toggle"/>
                </list>
            </field>
        </record>

        <record id="view_bhukhadan_area_master_form" model="ir.ui.view">
            <field name="name">bhukhadan.area.master.form</field>
            <field name="model">bhukhadan.area.master</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Area / क्षेत्र">
                    <sheet>
                        <group>
                            <field name="name" placeholder="Enter area name"/>
                            <field name="active"/>
                        </group>
                        <notebook>
                            <page string="Villages / ग्राम" name="villages">
                                <field name="village_ids" nolabel="1" readonly="1">
                                    <list string="Villages / ग्राम" create="0" delete="0" edit="0">
                                        <field name="village_code" string="Village Code"/>
                                        <field name="name" string="Village Name"/>
                                        <field name="name_english" string="English Name" optional="hide"/>
                                        <field name="state_id" string="State"/>
                                        <field name="district_id" string="District"/>
                                        <field name="sub_division_id" string="Sub Division" optional="hide"/>
                                        <field name="tehsil_id" string="Tehsil"/>
                                        <field name="pincode" string="Pincode" optional="hide"/>
                                        <field name="village_type" string="Type" optional="hide"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="view_bhukhadan_area_master_search" model="ir.ui.view">
            <field name="name">bhukhadan.area.master.search</field>
            <field name="model">bhukhadan.area.master</field>
            <field name="type">search</field>
            <field name="arch" type="xml">
                <search string="Search Areas / क्षेत्र खोजें">
                    <field name="name"/>
                    <filter string="Active / सक्रिय" name="active" domain="[('active', '=', True)]"/>
                    <filter string="Inactive / निष्क्रिय" name="inactive" domain="[('active', '=', False)]"/>
                </search>
            </field>
        </record>

        <record id="action_bhukhadan_area_master" model="ir.actions.act_window">
            <field name="name">Area Master / क्षेत्र मास्टर</field>
            <field name="res_model">bhukhadan.area.master</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_bhukhadan_area_master_search"/>
            <field name="context">{'search_default_active': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a new area
                </p>
                <p>
                    Areas are used to classify survey locations.
                </p>
            </field>
        </record>
    </data>
</odoo>
