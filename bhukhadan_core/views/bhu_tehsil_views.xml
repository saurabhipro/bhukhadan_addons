<odoo>
    <data>
                <!-- Tehsil Views -->
        <record id="bhu_tehsil_view_list" model="ir.ui.view">
            <field name="name">bhu.tehsil.view.list</field>
            <field name="model">bhu.tehsil</field>
            <field name="arch" type="xml">
                <list string="Tehsils / तहसील">
                    <field name="code"/>
                    <field name="name"/>
                    <field name="sub_division_id"/>
                    <field name="district_id"/>
                    <field name="state_id"/>
                    <field name="user_id" string="Tehsildar / तहसीलदार"/>
                </list>
            </field>
        </record>

        <record id="bhu_tehsil_view_form" model="ir.ui.view">
            <field name="name">bhu.tehsil.view.form</field>
            <field name="model">bhu.tehsil</field>
            <field name="arch" type="xml">
                <form string="Tehsil / तहसील">
                    <sheet>
                        <group>
                            <group>
                                <field name="state_id" options="{'no_create':True,'no_create_edit':True,'no_open':True}"/>
                                <field name="district_id" options="{'no_create':True,'no_create_edit':True,'no_open':True}" domain="[('state_id', '=', state_id)]"/>
                                <field name="sub_division_id" options="{'no_create':True,'no_create_edit':True,'no_open':True}" domain="[('district_id', '=', district_id)]"/>
                                <field name="code"/>
                                <field name="name"/>
                                <field name="user_id" domain="[('bhuarjan_role','=', 'tahsildar')]" options="{'no_create_edit':True, 'no_create':True}"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Villages / गांव">
                                    <field name="village_line_ids" widget="one2many_list" no_label="1"/>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter groups="bhukhadan_core.group_bhuarjan_ri,bhukhadan_core.group_bhuarjan_nayab_tahsildar,bhukhadan_core.group_bhuarjan_tahsildar,bhukhadan_core.group_bhuarjan_sdm,bhukhadan_core.group_bhuarjan_additional_collector,bhukhadan_core.group_bhuarjan_collector,bhukhadan_core.group_bhuarjan_admin"/>

                </form>
            </field>
        </record>

        <record id="bhu_tehsil_view_search" model="ir.ui.view">
            <field name="name">bhu.tehsil.view.search</field>
            <field name="model">bhu.tehsil</field>
            <field name="arch" type="xml">
                <search string="Search Tehsils / तहसील खोजें">
                    <field name="code"/>
                    <field name="name"/>
                    <field name="district_id"/>
                    
                    <group expand="0" string="Group By / समूह बनाएं">
                        <filter string="District / जिला" name="group_district" context="{'group_by': 'district_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_bhu_tehsil" model="ir.actions.act_window">
            <field name="name">Tehsils / तहसील</field>
            <field name="res_model">bhu.tehsil</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="bhu_tehsil_view_search"/>
        </record>
    </data>
</odoo>