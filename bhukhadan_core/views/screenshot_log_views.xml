<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_bhu_screenshot_log_list" model="ir.ui.view">
        <field name="name">bhu.screenshot.log.list</field>
        <field name="model">bhu.screenshot.log</field>
        <field name="arch" type="xml">
            <list string="Screenshot Audit Log" create="false" edit="false" delete="true">
                <field name="event_time"/>
                <field name="user_id"/>
                <field name="user_login" optional="show"/>
                <field name="user_mobile" optional="show"/>
                <field name="user_role" optional="hide"/>
                <field name="ip_address"/>
                <field name="platform"/>
                <field name="screen_name"/>
                <field name="survey_id" optional="show"/>
                <field name="device_info" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_bhu_screenshot_log_form" model="ir.ui.view">
        <field name="name">bhu.screenshot.log.form</field>
        <field name="model">bhu.screenshot.log</field>
        <field name="arch" type="xml">
            <form string="Screenshot Audit Event" create="false" edit="false" delete="true">
                <sheet>
                    <group>
                        <group string="Who">
                            <field name="user_id"/>
                            <field name="user_login"/>
                            <field name="user_mobile"/>
                            <field name="user_role"/>
                        </group>
                        <group string="When / Where">
                            <field name="event_time"/>
                            <field name="ip_address"/>
                            <field name="platform"/>
                            <field name="screen_name"/>
                            <field name="survey_id"/>
                        </group>
                    </group>
                    <group string="Device">
                        <field name="device_info"/>
                        <field name="user_agent"/>
                    </group>
                    <group string="Notes">
                        <field name="notes" colspan="2" nolabel="1"/>
                    </group>
                    <group string="Raw Payload" groups="base.group_no_one">
                        <field name="raw_payload" colspan="2" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_bhu_screenshot_log_search" model="ir.ui.view">
        <field name="name">bhu.screenshot.log.search</field>
        <field name="model">bhu.screenshot.log</field>
        <field name="arch" type="xml">
            <search string="Screenshot Audit">
                <field name="user_id"/>
                <field name="user_login"/>
                <field name="ip_address"/>
                <field name="screen_name"/>
                <field name="platform"/>
                <field name="survey_id"/>
                <filter string="Today" name="today"
                        domain="[('event_time', '&gt;=', (context_today()).strftime('%Y-%m-%d 00:00:00'))]"/>
                <separator/>
                <filter string="Android" name="android" domain="[('platform', '=', 'android')]"/>
                <filter string="iOS" name="ios" domain="[('platform', '=', 'ios')]"/>
                <group expand="0" string="Group By">
                    <filter string="User" name="group_user" context="{'group_by': 'user_id'}"/>
                    <filter string="IP" name="group_ip" context="{'group_by': 'ip_address'}"/>
                    <filter string="Platform" name="group_platform" context="{'group_by': 'platform'}"/>
                    <filter string="Screen" name="group_screen" context="{'group_by': 'screen_name'}"/>
                    <filter string="Event Day" name="group_day" context="{'group_by': 'event_time:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_bhu_screenshot_log" model="ir.actions.act_window">
        <field name="name">Screenshot Audit Log</field>
        <field name="res_model">bhu.screenshot.log</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_bhu_screenshot_log_search"/>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No screenshot events yet.
            </p>
            <p>
                Events are created when the mobile app reports a detected screenshot.
            </p>
        </field>
    </record>
</odoo>
