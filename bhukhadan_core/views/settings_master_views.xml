<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        
        <!-- Settings Master Form View -->
        <record id="view_bhuarjan_settings_master_form" model="ir.ui.view">
            <field name="name">bhuarjan.settings.master.form</field>
            <field name="model">bhuarjan.settings.master</field>
            <field name="arch" type="xml">
                <form string="BhuKhadan Settings Master">
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name"/>
                            </h1>
                        </div>
                        <div class="alert alert-info" role="alert" style="margin-top: 10px;">
                            <strong>Global Settings:</strong> These settings apply to all projects in the system.
                        </div>
                        
                        <notebook>
                            <!-- AWS Configuration Tab -->
                            <page string="AWS Configuration" name="aws_configuration">
                                <div class="alert alert-info" role="alert">
                                    <strong>AWS Configuration</strong><br/>
                                    Configure AWS S3 settings for file storage and management.
                                </div>
                                
                                <group col="2">
                                    <group>
                                        <field name="s3_bucket_name" placeholder="e.g., ddnsambha"/>
                                        <field name="aws_region" placeholder="e.g., ap-south-1"/>
                                    </group>
                                    <group>
                                        <field name="aws_access_key" placeholder="e.g., AKIAX3YCG3CX33RU"/>
                                        <field name="aws_secret_key" widget="password" placeholder="Enter AWS Secret Key"/>
                                    </group>
                                </group>
                            </page>
                            
                            <!-- OTP API Settings Tab -->
                            <page string="OTP API Settings" name="otp_api_settings">
                                <div class="alert alert-info" role="alert">
                                    <strong>OTP API Configuration</strong><br/>
                                    Configure OTP API settings for sending SMS messages.
                                </div>
                                
                                <group col="2">
                                    <group>
                                        <field name="otp_api_url" placeholder="e.g., https://api.example.com/otp"/>
                                        <field name="otp_api_key" placeholder="Enter OTP API Key"/>
                                        <field name="otp_client_id" placeholder="Enter OTP Client ID"/>
                                    </group>
                                    <group>
                                        <field name="otp_sender_id" placeholder="e.g., BHUAJN"/>
                                        <field name="otp_dlt_template_id" placeholder="Enter DLT Template ID"/>
                                    </group>
                                </group>
                                <group>
                                    <field name="otp_message_template" placeholder="Enter OTP Message Template"/>
                                    <field name="android_app_hash" placeholder="e.g. FA+9qCX9VSu"/>
                                </group>
                                
                                <div class="alert alert-success" role="alert" style="margin-top: 16px;">
                                    <strong>Test SMS Configuration</strong><br/>
                                    Enter a mobile number and click the button to test if the OTP SMS is sent successfully.
                                </div>
                                <group col="6">
                                    <field name="test_mobile_number" placeholder="Enter Mobile Number"/>
                                    <field name="test_otp" placeholder="Enter 4-digit OTP"/>
                                    <button name="action_test_sms" string="Send Test SMS" type="object" class="btn btn-primary" icon="fa-paper-plane"/>
                                </group>
                                
                                <separator string="Test SMS Configuration" style="margin-top: 20px; font-weight: bold; border-bottom: 2px solid #dee2e6; padding-bottom: 5px;"/>
                                <field name="api_documentation" widget="text" style="min-height: 300px; font-family: monospace; background-color: #f8f9fa; padding: 10px; border: 1px solid #dee2e6; border-radius: 4px;" readonly="1"/>

                                <div class="alert alert-warning" role="alert" style="margin-top: 16px;">
                                    <strong>Static OTP Configuration</strong><br/>
                                    Enable static OTP to use a fixed OTP value instead of sending SMS. This is useful when SMS API is disabled or for testing purposes.
                                </div>
                                
                                <group col="2">
                                    <group>
                                        <field name="enable_static_otp"/>
                                    </group>
                                    <group>
                                        <field name="static_otp_value" placeholder="e.g., 1234"/>
                                    </group>
                                </group>
                            </page>

                            <!-- Payment / Bank API Tab -->
                            <page string="Payment / Bank API" name="payment_bank_api_settings">
                                <notebook>
                                    <page string="Setup" name="bank_api_setup">
                                        <div class="alert alert-info py-2 mb-2" role="alert">
                                            <strong>IBL Domestic Payment Service</strong> — fields marked <strong>*</strong> are mandatory per IndusInd API specification.
                                        </div>
                                        <group col="2">
                                            <group string="API gateway">
                                                <field name="bank_soap_api_url"
                                                       placeholder="https://indusapiuat.indusind.bank.in/.../domesticpayservice/v1"/>
                                                <field name="bank_ibl_client_id" placeholder="IBL-Client-Id"/>
                                                <field name="bank_ibl_client_secret" widget="password" placeholder="IBL-Client-Secret"/>
                                                <field name="bank_api_append_operation_path"/>
                                            </group>
                                            <group string="Corporate IDs &amp; accounts">
                                                <field name="bank_customer_id" placeholder="CustomerID / strCustId"/>
                                                <field name="bank_user_id" placeholder="UserID"/>
                                                <field name="bank_account_number" placeholder="Balance / statement account"/>
                                                <field name="debit_account_number" placeholder="Debit account for payments"/>
                                            </group>
                                        </group>
                                    </page>

                                    <page string="1 · Balance" name="bank_api_balance">
                                        <div class="alert alert-secondary py-2 mb-2" role="alert">
                                            <strong>GetAccBalance</strong> — uses <strong>Customer ID *</strong>, <strong>User ID *</strong> and <strong>Account Number *</strong> from Setup.
                                        </div>
                                        <div class="text-end mb-2">
                                            <button name="action_test_bank_get_acc_balance" string="Test GetAccBalance"
                                                    type="object" class="btn btn-primary" icon="fa-university"/>
                                        </div>
                                    </page>

                                    <page string="2 · Payment" name="bank_api_payment">
                                        <div class="alert alert-secondary py-2 mb-2" role="alert">
                                            <strong>ProcessTxnInXml</strong> — <strong>*</strong> = mandatory (CustomerRefNum, DebitAccount on Setup tab, Amount, ValueDate, BenName, BENE_ACNO, MakerId, CheckerId).
                                        </div>
                                        <group col="2">
                                            <group>
                                                <field name="bank_txn_tran_type"/>
                                                <field name="bank_txn_customer_ref" placeholder="Unique customer ref"/>
                                                <field name="bank_txn_amount"/>
                                                <field name="bank_txn_value_date" placeholder="DD-MM-YYYY"/>
                                                <field name="bank_txn_ben_name"/>
                                                <field name="bank_txn_bene_acno"/>
                                                <field name="bank_txn_bene_ifsc"/>
                                            </group>
                                            <group>
                                                <field name="bank_txn_bene_branch"/>
                                                <field name="bank_txn_bene_bank"/>
                                                <field name="bank_txn_bene_mobile"/>
                                                <field name="bank_txn_bene_email"/>
                                                <field name="bank_txn_bene_mmid"/>
                                                <field name="bank_txn_maker_id"/>
                                                <field name="bank_txn_checker_id"/>
                                            </group>
                                        </group>
                                        <div class="text-end mt-2">
                                            <button name="action_test_bank_process_txn" string="Test ProcessTxnInXml"
                                                    type="object" class="btn btn-primary" icon="fa-money"/>
                                        </div>
                                    </page>

                                    <page string="3 · Enquiry" name="bank_api_enquiry">
                                        <div class="alert alert-secondary py-2 mb-2" role="alert">
                                            <strong>GetTxnResponseInXml</strong> — requires <strong>Customer ID *</strong> (Setup) and <strong>IBL Ref No *</strong>.
                                        </div>
                                        <group>
                                            <field name="bank_test_ibl_ref_no" placeholder="e.g. DFG4DT0000118082"/>
                                        </group>
                                        <div class="text-end mt-2">
                                            <button name="action_test_bank_get_txn_response" string="Test GetTxnResponseInXml"
                                                    type="object" class="btn btn-primary" icon="fa-search"/>
                                        </div>
                                    </page>

                                    <page string="4 · Statement" name="bank_api_statement">
                                        <div class="alert alert-secondary py-2 mb-2" role="alert">
                                            <strong>GetStatement</strong> — requires Setup IDs/accounts plus <strong>From Date *</strong> and <strong>To Date *</strong> (DD-MM-YYYY).
                                        </div>
                                        <group col="2">
                                            <field name="bank_stmt_from_date" placeholder="DD-MM-YYYY"/>
                                            <field name="bank_stmt_to_date" placeholder="DD-MM-YYYY"/>
                                        </group>
                                        <div class="text-end mt-2">
                                            <button name="action_test_bank_get_statement" string="Test GetStatement"
                                                    type="object" class="btn btn-primary" icon="fa-list-alt"/>
                                        </div>
                                    </page>

                                    <page string="5 · Returns" name="bank_api_returns">
                                        <div class="alert alert-secondary py-2 mb-2" role="alert">
                                            <strong>GetReturnTrxn</strong> — requires <strong>Customer ID *</strong> from Setup tab.
                                        </div>
                                        <div class="text-end mt-2">
                                            <button name="action_test_bank_get_return_trxn" string="Test GetReturnTrxn"
                                                    type="object" class="btn btn-primary" icon="fa-undo"/>
                                        </div>
                                    </page>

                                    <page string="API Log" name="bank_api_log">
                                        <group col="2">
                                            <field name="bank_api_last_method" readonly="1"/>
                                            <field name="bank_api_last_url" readonly="1"/>
                                        </group>
                                        <group col="2">
                                            <field name="bank_api_last_request" readonly="1" widget="text" nolabel="1"
                                                   placeholder="Last SOAP request will appear here..."
                                                   style="min-height: 220px; font-family: monospace; font-size: 11px;"/>
                                            <field name="bank_api_last_response" readonly="1" widget="text" nolabel="1"
                                                   placeholder="Last SOAP response will appear here..."
                                                   style="min-height: 220px; font-family: monospace; font-size: 11px;"/>
                                        </group>
                            </page>
                        </notebook>
                    </page>

                            <!-- Mobile App APK Tab -->
                            <page string="Mobile App" name="mobile_app_settings">
                                <div class="alert alert-info" role="alert">
                                    <strong>Android APK Configuration</strong><br/>
                                    Upload the latest BhuKhadan Field App APK with version and release date.
                                    After saving, the file is available for download from the public website header and footer.
                                </div>
                                <group col="2">
                                    <group string="Release details">
                                        <field name="mobile_apk_version" placeholder="e.g. 2.4.1"/>
                                        <field name="mobile_apk_release_date"/>
                                    </group>
                                    <group string="APK file">
                                        <field name="mobile_apk_file" filename="mobile_apk_filename"/>
                                        <field name="mobile_apk_filename" invisible="1"/>
                                    </group>
                                </group>
                                <div class="alert alert-secondary" role="alert">
                                    Public download URL (after save):
                                    <strong>/bhuarjan/mobile-app/download</strong>
                                </div>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Settings Master Tree View -->
        <record id="view_bhuarjan_settings_master_tree" model="ir.ui.view">
            <field name="name">bhuarjan.settings.master.tree</field>
            <field name="model">bhuarjan.settings.master</field>
            <field name="arch" type="xml">
                <list string="BhuKhadan Settings Master" decoration-info="active == True" decoration-muted="active == False">
                    <field name="name"/>
                    <field name="active" widget="boolean_toggle"/>
                </list>
            </field>
        </record>

        <!-- Settings Master Search View -->
        <record id="view_bhuarjan_settings_master_search" model="ir.ui.view">
            <field name="name">bhuarjan.settings.master.search</field>
            <field name="model">bhuarjan.settings.master</field>
            <field name="arch" type="xml">
                <search string="BhuKhadan Settings Master">
                    <field name="name"/>
                    <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                    <filter string="Inactive" name="inactive" domain="[('active', '=', False)]"/>
                </search>
            </field>
        </record>

        <!-- Actions -->
        <record id="action_bhuarjan_settings_master_tree" model="ir.actions.act_window">
            <field name="name">Settings Master</field>
            <field name="res_model">bhuarjan.settings.master</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_bhuarjan_settings_master_search"/>
            <field name="context">{'search_default_active': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create Settings Master
                </p>
                <p>
                    Configure global system settings that apply to all projects.
                </p>
            </field>
        </record>

    </data>
</odoo>
