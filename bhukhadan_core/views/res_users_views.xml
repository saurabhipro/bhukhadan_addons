<odoo>
    <data>
        <record id="action_bhu_mapped_google_sheet" model="ir.actions.act_url">
            <field name="name">Google Docs</field>
            <field name="url">https://docs.google.com/spreadsheets/d/1JqffBfWRDWAtJL-5MyKJQxa71RlylIkwDUjuaBMa9sw/edit?pli=1&amp;gid=1569404633#gid=1569404633</field>
            <field name="target">new</field>
        </record>

        <record id="res_users_view_form_inherit" model="ir.ui.view">
          <field name="name">res.users.view.form.inherit.bhuarjan</field>
          <field name="model">res.users</field>
          <field name="inherit_id" ref="base.view_users_form"/>
          <field name="arch" type="xml">

              <xpath expr="//sheet/div[@class='oe_title']/h1/field[@name='name']" position="after">
                    <label for="name_english" string="Name (English)"/>
                    <field name="name_english" placeholder="Romanized or English spelling"/>
              </xpath>
              <xpath expr="//notebook" position="before">
                    <group string="BhuKhadan">
                        <group>
                            <field name="parent_id" options="{'no_create':True,'no_create_edit':True,'no_open':True}"/>
                            <field name="state_id" options="{'no_create':True,'no_create_edit':True,'no_open':True}"/>
                            <field name="district_id" domain="[('state_id', '=', state_id)]" 
                                   options="{'no_create':True,'no_create_edit':True,'no_open':True}"/>
                            <field name="bhu_scope_sub_division_summary" readonly="1" widget="bhu_comma_pills_subdiv"/>
                            <field name="bhu_scope_tehsil_summary" readonly="1" widget="bhu_comma_pills_tehsil"/>
                        </group>
                    </group>
                    <group string="Patwari — mapped villages / पटवारी गाँव" colspan="2"
                           invisible="bhuarjan_role != 'halka_patwari'">
                        <field name="bhu_patwari_village_summary" readonly="1" colspan="2" widget="bhu_comma_pills_villages"/>
                        <field name="bhu_patwari_village_ids" nolabel="1" colspan="2" readonly="1">
                            <list>
                                <field name="name"/>
                                <field name="village_code"/>
                                <field name="tehsil_id"/>
                            </list>
                        </field>
                    </group>
                    <group string="Subordinates" invisible="1">
                        <field name="child_ids" options="{'no_create':True,'no_create_edit':True,'no_open':True}"/>
                    </group>
              </xpath>
          </field>
      </record>


        <record id="inherit_res_users_tree_views_bhuarjan" model="ir.ui.view">
            <field name="name">res.users.inherit.list</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="base.view_users_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//list" position="inside">
                    <header>
                        <button name="%(action_bhu_mapped_google_sheet)d" type="action" string="Google Docs"
                                icon="fa-external-link"
                                groups="base.group_system,bhukhadan_core.group_bhuarjan_admin"/>
                        <button name="action_reconcile_patwari_google_sheet" type="object" string="Reconcile"
                                icon="fa-exchange"
                                groups="base.group_system,bhukhadan_core.group_bhuarjan_admin"/>
                    </header>
                </xpath>
                <!-- Hide native name column in list; show English name instead -->
                <xpath expr="//field[@name='name']" position="attributes">
                    <attribute name="column_invisible">1</attribute>
                </xpath>
                <!-- Role + English name columns (name_english replaces visible name) -->
                <xpath expr="//field[@name='name']" position="after">
                    <field name="name_english" string="Name (English)"/>
                    <field name="bhuarjan_role" string="BhuKhadan Role" widget="badge" 
                           decoration-info="bhuarjan_role in ('halka_patwari', 'revenue_inspector', 'area_survey_officer', 'staff_officer_pp', 'staff_officer_hr', 'staff_officer_civil')" 
                           decoration-warning="bhuarjan_role in ('tehsildar', 'nodal_officer_lr', 'sub_area_manager_gm_min')" 
                           decoration-danger="bhuarjan_role in ('general_manager_oprn', 'area_finance_manager')" 
                           decoration-success="bhuarjan_role in ('sub_engineer', 'pwd_officer', 'deputy_forest_officer', 'forest_range_officer', 'horticulture_superintendent')"/>
                </xpath>
                <xpath expr="//field[@name='login']" position="after">
                    <field name="mobile"/>
                    <field name="parent_id" column_invisible="True"/>
                    <field name="state_id" column_invisible="True"/>
                    <field name="district_id" string="District"/>
                    <field name="bhu_scope_sub_division_summary" string="Sub Division" optional="show"
                           widget="bhu_comma_pills_subdiv"/>
                    <field name="bhu_scope_tehsil_summary" string="Tehsil" optional="show"
                           widget="bhu_comma_pills_tehsil"/>
                    <field name="bhu_patwari_village_summary" string="Villages"
                           optional="show" widget="bhu_comma_pills_villages"/>
                    <field name="child_ids" widget="many2many_tags" column_invisible="True"/>
                </xpath>
                <!-- Hide Language column -->
                <xpath expr="//field[@name='lang']" position="attributes">
                    <attribute name="column_invisible">1</attribute>
                    <attribute name="invisible">1</attribute>
                </xpath>
                <!-- Hide Latest authentication (login_date) column -->
                <xpath expr="//field[@name='login_date']" position="attributes">
                    <attribute name="column_invisible">1</attribute>
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='company_id']" position="attributes">
                    <attribute name="column_invisible">1</attribute>
                </xpath>
            </field>
        </record>

      <!-- Res user own custom view -->

      <record id="res_users_bhuarjan_view_form_inherit" model="ir.ui.view">
            <field name="name">res.users.view.form</field>
            <field name="model">res.users</field>
            <field name="arch" type="xml">
                <form string="Users">
                    <sheet>
                        <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                        <div class="alert alert-info text-center o_form_header" invisible="active and active_partner or not active and not active_partner or active and not active_partner" role="alert">
                          <a class="close" data-bs-dismiss="alert" href="#">x</a>
                          <div>
                            <strong>The contact linked to this user is still active</strong>
                          </div>
                          <div>You can archive the contact
                            <field name="partner_id" required="0" readonly="1"/>
                          </div>
                        </div>
                        <field name="image_1920" widget="image" class="oe_avatar" options="{&quot;preview_image&quot;: &quot;avatar_128&quot;}"/>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1><field name="name" placeholder="e.g. John Doe" required="1" readonly="0"/></h1>
                            <label for="name_english" string="Name (English)"/>
                            <field name="name_english" placeholder="Romanized or English spelling"/>
                            <field name="email" invisible="1"/><!-- needed to update partner's email from on_change_login() -->
                            <label for="login" string="Email Address"/>
                            <h2><field name="login" placeholder="e.g. email@yourcompany.com" readonly="0"/></h2>
                            <group>
                                <field name="partner_id" groups="base.group_no_one" readonly="1" required="0" invisible="not id"/>
                            </group>
                            <group>
                                <field name="mobile" readonly="0"/>
                            </group>
                            <group>
                                <field name="department_color" widget="color"/>
                            </group>
                        </div>
                        <group string="BhuKhadan">
                            <group>
                                <field name="active" string="Active / सक्रिय"/>
                                <field name="bhuarjan_role"/>
                                <field name="company_ids" widget="many2many_tags" options="{'no_create':True}" string="Allowed Companies"/>
                                <field name="parent_id" options="{'no_create':True,'no_create_edit':True,'no_open':True}"/>
                                <field name="state_id" options="{'no_create':True,'no_create_edit':True,'no_open':True}"/>
                                <field name="district_id" domain="[('state_id', '=', state_id)]" options="{'no_create':True,'no_create_edit':True,'no_open':True}"/>
                                <field name="bhu_scope_sub_division_summary" readonly="1" widget="bhu_comma_pills_subdiv"/>
                                <field name="bhu_scope_tehsil_summary" readonly="1" widget="bhu_comma_pills_tehsil"/>
                            </group>
                        </group>
                        <group string="Patwari — mapped villages / पटवारी गाँव" colspan="2"
                               invisible="bhuarjan_role != 'halka_patwari'">
                            <field name="bhu_patwari_village_summary" readonly="1" colspan="2" widget="bhu_comma_pills_villages"/>
                            <field name="bhu_patwari_village_ids" nolabel="1" colspan="2" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="village_code"/>
                                    <field name="tehsil_id"/>
                                </list>
                            </field>
                        </group>
                        <group string="Subordinates" invisible="1">
                            <field name="child_ids" options="{'no_create':True,'no_create_edit':True,'no_open':True}"/>
                        </group>

                        <group string="User Group">
                            <field name="bhuarjan_category_id" invisible="1"/>
                            <field name="groups_id" widget="many2many_tags" domain="[('category_id', '=', bhuarjan_category_id)]" options="{'no_create':True,'no_create_edit':True,'no_open':True}"/>
                        </group>

                        <group string="Additional Mobile Numbers / अतिरिक्त मोबाइल नंबर">
                            <field name="mobile_number_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="mobile" string="Mobile Number"/>
                                    <field name="label" string="Label (e.g. Personal, Office)"/>
                                    <field name="active" string="Active"/>
                                </list>
                            </field>
                        </group>

                    </sheet>
                </form>
            </field>
        </record>


        <record id="view_bhu_res_users_kanban" model="ir.ui.view">
    <field name="name">res.users.kanban.bhuarjan</field>
    <field name="model">res.users</field>
    <field name="arch" type="xml">
        <kanban class="o_kanban_mobile">
            <!-- Include any fields you plan to display -->
            <field name="active"/>
            <field name="mobile"/>
            <field name="login_date"/>
            <field name="parent_id"/>
            <field name="state_id"/>
            <field name="district_id"/>
            <field name="child_ids"/>

            <templates>
                <t t-name="card" class="flex-row">
                    <aside class="w-25 p-1">
                        <field name="avatar_128" widget="image" alt="Avatar"/>
                    </aside>
                    <main class="w-100 ps-2 pt-1">
                        <div>
                            <div t-if="record.active.raw_value" class="text-success float-end mb4">
                                <i class="fa fa-circle" role="img" aria-label="Active" title="Active"/>
                            </div>
                            <div t-else="" class="text-danger float-end mb4">
                                <i class="fa fa-circle" role="img" aria-label="Inactive" title="Inactive"/>
                            </div>
                            <field class="fw-bold" name="name"/>
                        </div>

                        <div>
                            <span class="mb4 text-truncate" title="Login">
                                <i class="fa fa-envelope me-1" role="img" aria-label="Login"/>
                                <field name="login"/>
                            </span>
                            <field class="badge rounded-pill float-end" name="lang"/>
                        </div>

                        <!-- Additional fields section -->
                        <div class="mt-2 small text-muted">

                            <div t-if="record.parent_id.raw_value">
                                <b>Parent:</b> <field name="parent_id"/>
                            </div>

                            <div t-if="record.state_id.raw_value">
                                <b>State:</b> <field name="state_id"/>
                            </div>

                            <div t-if="record.district_id.raw_value">
                                <b>District:</b> <field name="district_id"/>
                            </div>

                            <div t-if="record.child_ids.raw_value">
                                <b>Child:</b>
                                <field name="child_ids" widget="many2many_tags"/>
                            </div>

                        </div>
                    </main>
                </t>
            </templates>
        </kanban>
    </field>
</record>


    
    <!-- Beautiful Organization Chart View -->
    <record id="organization_chart_view" model="ir.ui.view">
        <field name="name">Organization Chart View</field>
        <field name="model">res.users</field>
        <field name="arch" type="xml">
            
        <hierarchy
            child_field="child_ids"
            js_class="hr_employee_hierarchy"
            icon="fa-users"
            draggable="0"
            string="User Hierarchy"
            default_order="name"
        >
            <field name="name"/>
            <field name="email"/>
            <field name="department_color"/>
            <field name="image_1024"/>
            <field name="parent_id"/>
            <field name="child_ids"/>

            <templates>
                <t t-name="hierarchy-box">
                    <div class="o_hierarchy_node_header d-flex justify-content-center pb-4"
t-att-style="'background-color:' + (record.department_color.raw_value or '#692020ff') + ';'"
                        t-att-title="record.value">
                        <field
                            name="image_1024"
                            preview_image="image_128"
                            widget="background_image"
                            options="{'zoom': true, 'zoom_delay': 1000}"
                        />
                    </div>

        <div class="d-flex flex-column text-center p-2">
            <div class="d-flex align-items-center justify-content-center">
                <field class="fw-bold w-100" name="name"/>
            </div>
            <div class="text-muted small">
                <field name="email"/>
            </div>
        </div>
    </t>
</templates>
        </hierarchy>



        </field>
    </record>

    <!-- res.users Graph View -->
    <record id="view_res_users_graph" model="ir.ui.view">
        <field name="name">res.users.graph</field>
        <field name="model">res.users</field>
        <field name="arch" type="xml">
            <graph string="Users Analysis" type="bar" sample="1">
                <field name="district_id"/>
                <field name="bhuarjan_role"/>
            </graph>
        </field>
    </record>

    <!-- res.users Pivot View -->
    <record id="view_res_users_pivot" model="ir.ui.view">
        <field name="name">res.users.pivot</field>
        <field name="model">res.users</field>
        <field name="arch" type="xml">
            <pivot string="Users Analysis" sample="1">
                <field name="district_id" type="row"/>
                <field name="bhuarjan_role" type="col"/>
            </pivot>
        </field>
    </record>


        <!-- Inherit search view to add mobile field -->
        <record id="view_users_search_inherit" model="ir.ui.view">
            <field name="name">res.users.search.inherit</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="base.view_users_search"/>
            <field name="arch" type="xml">
                <!-- Main search bar: include English name -->
                <xpath expr="//field[@name='name']" position="attributes">
                    <attribute name="filter_domain">['|', '|', '|', ('name','ilike',self), ('login','ilike',self), ('email','ilike',self), ('name_english','ilike',self)]</attribute>
                </xpath>
                <!-- Add mobile field to search -->
                <xpath expr="//field[@name='name']" position="after">
                    <field name="name_english" string="Name (English)"/>
                    <field name="mobile" string="Mobile"/>
                </xpath>
                <!-- Add mobile filter - add inside search element after fields -->
                <xpath expr="//search" position="inside">
                    <filter string="Has Mobile" name="has_mobile" domain="[('mobile', '!=', False)]"/>
                    <group expand="0" string="Group By">
                        <filter string="District" name="groupby_district" context="{'group_by': 'district_id'}"/>
                        <filter string="Role" name="groupby_role" context="{'group_by': 'bhuarjan_role'}"/>
                    </group>
                </xpath>
                <xpath expr="//search" position="inside">
                    <searchpanel>
                        <field name="district_id" icon="fa-map-marker" string="District" enable_counters="1"/>
                        <field name="bhuarjan_role" icon="fa-users" string="Role" enable_counters="1"/>
                    </searchpanel>
                </xpath>
            </field>
        </record>

        <record id="action_accres_users_bhuarjan_view_form_action" model="ir.actions.act_window">
            <field name="name">Users</field>
            <field name="res_model">res.users</field>
            <field name="view_mode">list,kanban,graph,pivot,hierarchy,form</field>
            <field name="context">{'search_default_groupby_district': 1}</field>
            <field name="view_ids" eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'list', 'view_id': ref('base.view_users_tree')}),
                (0, 0, {'view_mode': 'kanban', 'view_id': ref('view_bhu_res_users_kanban')}),
                (0, 0, {'view_mode': 'hierarchy', 'view_id': ref('organization_chart_view')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('res_users_bhuarjan_view_form_inherit')})]"/>
        </record>

        <!-- Customize User Preferences Dialog -->
        <record id="view_users_form_simple_modif_bhuarjan" model="ir.ui.view">
            <field name="name">res.users.preferences.bhuarjan</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="base.view_users_form_simple_modif"/>
            <field name="arch" type="xml">
                
                <xpath expr="//notebook" position="before">
                    <group string="My Details">
                        <group>
                            <field name="login" readonly="1"/>
                            <field name="mobile" readonly="1"/>
                            <field name="name_english" readonly="1"/>
                            <field name="bhuarjan_role" readonly="1" string="Role"/>
                        </group>
                        <group>
                            <field name="parent_id" readonly="1" options="{'no_open':True}" string="Reporting"/>
                            <field name="state_id" readonly="1" options="{'no_open':True}"/>
                            <field name="company_id" readonly="1" options="{'no_open':True}"/>
                        </group>
                    </group>
                    <group string="Assigned Projects / आवंटित परियोजनाएं">
                        <field name="assigned_project_ids" nolabel="1" readonly="1" widget="many2many_tags"/>
                    </group>
                </xpath>
               <xpath expr="//notebook" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
               
                
            </field>
        </record>


    </data>
</odoo>