<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Group Dashboard Action -->
        <record id="action_group_dashboard" model="ir.actions.client">
            <field name="name">Group Dashboard</field>
            <field name="tag">bhukhadan_core.group_dashboard</field>
            <field name="target">current</field>
        </record>

        <!-- Management Dashboard (portfolio / leadership KPIs) -->
        <record id="action_management_dashboard" model="ir.actions.client">
            <field name="name">Management Dashboard</field>
            <field name="tag">bhukhadan_core.management_dashboard</field>
            <field name="target">current</field>
        </record>

        <!-- Hidden Group Dashboard Menu -->
        <menuitem
            id="menu_group_dashboard"
            name="Group Dashboard (Hidden)"
            parent="menu_bhu_root"
            action="action_group_dashboard"
            sequence="0"
            active="False"
            groups="base.group_system"/>

        <!-- Insights: Group + Management dashboards for leadership -->
        <menuitem
            id="menu_bhu_insights"
            name="Insights"
            parent="menu_bhu_root"
            sequence="97"
            groups="bhukhadan_core.group_bhuarjan_admin,base.group_system,bhukhadan_core.group_bhuarjan_collector,bhukhadan_core.group_bhuarjan_additional_collector,bhukhadan_core.group_bhuarjan_district_administrator,bhukhadan_core.group_bhuarjan_sdm"/>

        <!-- SDM subdivision portfolio + village pipeline (OWL) -->
        <record id="action_sdm_pipeline_dashboard" model="ir.actions.client">
            <field name="name">SDM Pipeline Dashboard</field>
            <field name="tag">bhukhadan_core.sdm_pipeline_dashboard</field>
            <field name="target">current</field>
        </record>

        <menuitem
            id="menu_sdm_pipeline_dashboard"
            name="SDM Pipeline Dashboard"
            parent="menu_bhu_insights"
            action="action_sdm_pipeline_dashboard"
            sequence="3"
            groups="bhukhadan_core.group_bhuarjan_admin,base.group_system,bhukhadan_core.group_bhuarjan_district_administrator,bhukhadan_core.group_bhuarjan_sdm"/>

        <record id="menu_group_dashboard_admin" model="ir.ui.menu">
            <field name="name">Group Dashboard</field>
            <field name="parent_id" ref="menu_bhu_insights"/>
            <field name="action" ref="action_group_dashboard"/>
            <field name="sequence" eval="1"/>
            <field name="groups_id" eval="[(6, 0, [ref('base.group_system')])]"/>
        </record>

        <menuitem
            id="menu_management_dashboard"
            name="Management Dashboard"
            parent="menu_bhu_insights"
            action="action_management_dashboard"
            sequence="2"
            groups="bhukhadan_core.group_bhuarjan_admin,base.group_system,bhukhadan_core.group_bhuarjan_collector,bhukhadan_core.group_bhuarjan_additional_collector,bhukhadan_core.group_bhuarjan_district_administrator"/>
    </data>
</odoo>
