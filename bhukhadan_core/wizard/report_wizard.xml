<odoo>
    <!-- Wizard Form -->
    <record id="view_report_wizard_form" model="ir.ui.view">
        <field name="name">report.wizard.form</field>
        <field name="model">report.wizard</field>
        <field name="arch" type="xml">
            <form string="Generate Report">
                <group>
                    <field name="report_type" readonly="1"/>
                    <field name="allowed_village_ids" invisible="1"/>
                    <field name="project_id" required="1"/>
                    <field name="village_id" required="1" domain="[('id', 'in', allowed_village_ids)]"/>
                    <field name="export_type" string="Export Type" widget="radio" options="{'horizontal': true}"/>
                </group>
                <footer>
                    <button name="action_print_report"
                            string="Download"
                            type="object"
                            class="btn-primary"/>
                    <button name="action_cancel"
                            string="Cancel"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Wizard Action -->
    <record id="action_report_wizard" model="ir.actions.act_window">
        <field name="name">Report Wizard</field>
        <field name="res_model">report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_report_type': 'form5'}</field>
    </record>

    <record id="action_report_wizard_form5" model="ir.actions.act_window">
        <field name="name">Form 5 Download</field>
        <field name="res_model">report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_report_type': 'form5'}</field>
    </record>

    <record id="action_report_wizard_form6" model="ir.actions.act_window">
        <field name="name">Form 6 Download</field>
        <field name="res_model">report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_report_type': 'form6'}</field>
    </record>

    <record id="action_report_wizard_dols" model="ir.actions.act_window">
        <field name="name">DOLS Download</field>
        <field name="res_model">report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_report_type': 'dols'}</field>
    </record>


</odoo>
