<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_bhu_payment_voucher_generate_wizard_form" model="ir.ui.view">
        <field name="name">bhu.payment.voucher.generate.wizard.form</field>
        <field name="model">bhu.payment.voucher.generate.wizard</field>
        <field name="arch" type="xml">
            <form string="Generate Payment File" class="bhu_pv_generate_wizard">
                <sheet>
                    <div class="alert alert-info mb-3" role="alert">
                        <strong>Generating payment file for these khasras.</strong>
                        Review the summary below, choose how to proceed, then click
                        <strong>Generate</strong>.
                    </div>
                    <group>
                        <group>
                            <field name="voucher_id" readonly="1"/>
                            <field name="khasra_count"/>
                            <field name="beneficiary_count"/>
                        </group>
                        <group>
                            <field name="total_amount" widget="monetary"/>
                            <field name="khasra_summary"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <field name="preview_html" nolabel="1" readonly="1" widget="html"
                           class="bhu_pv_gen_preview_field"/>
                    <group string="How do you want to proceed? / आगे कैसे बढ़ें?">
                        <field name="delivery_mode" widget="radio" nolabel="1"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm_generate" type="object"
                            string="Generate / जेनरेट करें" class="btn-primary"/>
                    <button string="Cancel / रद्द" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_bhu_payment_voucher_generate_wizard" model="ir.actions.act_window">
        <field name="name">Generate Payment File</field>
        <field name="res_model">bhu.payment.voucher.generate.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
