<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="bhukhadan_core.TimelineComponent">
        <div class="o_e2e_timeline_section o_timeline_gradient_box" style="margin-bottom:12px; overflow:hidden;">

            <!-- Legend + toggle bar -->
            <div class="o_timeline_legend_bar" style="display:flex; align-items:center; justify-content:space-between; gap:8px; flex-wrap:wrap; padding:9px 14px;">
                <div style="display:flex; align-items:center; gap:10px; flex-wrap:wrap; font-size:12px; color:var(--bd-theme-primary, var(--spiffy-primary-color, var(--o-brand-odoo, #875A7B)));">
                    <span style="font-weight:700; color:var(--bd-theme-primary, var(--spiffy-primary-color, var(--o-brand-odoo, #875A7B))); letter-spacing:0.3px;">Section:</span>
                    <div style="display:flex; align-items:center; gap:4px;">
                        <i class="fa fa-file-o" style="font-size:11px; color:#9c7459;"/>
                        <span style="color:var(--bd-theme-primary, var(--spiffy-primary-color, var(--o-brand-odoo, #875A7B)));">Draft</span>
                    </div>
                    <div style="display:flex; align-items:center; gap:4px;">
                        <i class="fa fa-paper-plane" style="font-size:11px; color:#2b6cb0;"/>
                        <span style="color:var(--bd-theme-primary, var(--spiffy-primary-color, var(--o-brand-odoo, #875A7B)));">Submitted</span>
                    </div>
                    <div style="display:flex; align-items:center; gap:4px;">
                        <i class="fa fa-check-circle" style="font-size:11px; color:#276749;"/>
                        <span style="color:var(--bd-theme-primary, var(--spiffy-primary-color, var(--o-brand-odoo, #875A7B)));">Approved</span>
                    </div>
                    <div style="display:flex; align-items:center; gap:4px;">
                        <i class="fa fa-times-circle" style="font-size:11px; color:#c53030;"/>
                        <span style="color:var(--bd-theme-primary, var(--spiffy-primary-color, var(--o-brand-odoo, #875A7B)));">Returned</span>
                    </div>
                    <span style="color:#d4a574; margin:0 2px;">│</span>
                    <span style="font-weight:700; color:var(--bd-theme-primary, var(--spiffy-primary-color, var(--o-brand-odoo, #875A7B))); letter-spacing:0.3px;">E2E:</span>
                    <div style="display:flex; align-items:center; gap:4px;">
                        <i class="fa fa-circle" style="font-size:8px; color:#276749;"/>
                        <span style="color:var(--bd-theme-primary, var(--spiffy-primary-color, var(--o-brand-odoo, #875A7B)));">Done</span>
                    </div>
                    <div style="display:flex; align-items:center; gap:4px;">
                        <i class="fa fa-circle" style="font-size:8px; color:#c8640a;"/>
                        <span style="color:var(--bd-theme-primary, var(--spiffy-primary-color, var(--o-brand-odoo, #875A7B)));">Active</span>
                    </div>
                    <div style="display:flex; align-items:center; gap:4px;">
                        <i class="fa fa-circle" style="font-size:8px; color:#c4a882;"/>
                        <span style="color:var(--bd-theme-primary, var(--spiffy-primary-color, var(--o-brand-odoo, #875A7B)));">Pending</span>
                    </div>
                </div>
                <div class="o_timeline_header_actions">
                    <button type="button"
                            class="o_docvault_timeline_btn"
                            t-on-click.stop="() => this.openDocumentVaultNavigator()"
                            title="Open signed PDFs for this project and village">
                        <i class="fa fa-folder-open-o"/>
                        <span>Doc Vault Viewer</span>
                    </button>
                    <button type="button"
                            class="o_timeline_village_toggle_btn"
                            t-on-click="toggleTimeline">
                        <i class="fa fa-map-marker"/>
                        <span class="o_timeline_village_toggle_label">
                            Acquisition Status for Village
                            <t t-if="selectedVillageName">
                                <span class="o_timeline_village_name">· <t t-esc="selectedVillageName"/></span>
                            </t>
                        </span>
                        <i t-att-class="showTimeline ? 'fa fa-chevron-up' : 'fa fa-chevron-down'" class="o_timeline_toggle_chevron"/>
                    </button>
                </div>
            </div>

            <!-- Collapsible timeline body -->
            <div t-if="showTimeline" class="o_timeline_body" style="padding:14px 16px 12px;">

                <!-- Detect act type -->
                <t t-set="is_railways" t-value="allowedSectionNames &amp;&amp; allowedSectionNames.includes('Sec 20 A (Railways)')"/>
                <t t-set="is_nh"       t-value="allowedSectionNames &amp;&amp; allowedSectionNames.includes('Sec 3A (NH)')"/>
                <t t-set="is_cglrc"    t-value="allowedSectionNames &amp;&amp; allowedSectionNames.includes('Personal Notice generation (247.1)')"/>
                <t t-set="is_coal"     t-value="allowedSectionNames &amp;&amp; (allowedSectionNames.includes('Sec 4(i) Notification of intention to prospect') or allowedSectionNames.includes('(Sec 4) CBA Notification'))"/>

                <!-- Shared step states -->
                <t t-set="pv_done"   t-value="stats &amp;&amp; stats.payment_voucher_info &amp;&amp; stats.payment_voucher_info.is_completed"/>
                <t t-set="pv_active" t-value="stats &amp;&amp; (stats.payment_voucher_draft || 0) &gt; 0"/>
                <t t-set="pay_done"   t-value="stats &amp;&amp; stats.payment_file_info &amp;&amp; stats.payment_file_info.is_completed"/>
                <t t-set="pay_active" t-value="stats &amp;&amp; (stats.payment_file_draft || 0) &gt; 0"/>
                <t t-set="sur_done"   t-value="stats &amp;&amp; stats.survey_info &amp;&amp; stats.survey_info.is_completed"/>
                <t t-set="sur_active" t-value="stats &amp;&amp; stats.survey_info &amp;&amp; (stats.survey_info.submitted_count || stats.survey_info.approved_count) &amp;&amp; !stats.survey_info.is_completed"/>

                <!-- Build steps array based on act type -->
                <t t-if="is_railways">
                    <t t-set="r2_active" t-value="stats &amp;&amp; (stats.section20a_railways_total || 0) > 0"/>
                    <t t-set="r3_done"   t-value="stats &amp;&amp; stats.section23_award_info &amp;&amp; stats.section23_award_info.is_completed"/>
                    <t t-set="r3_active" t-value="stats &amp;&amp; stats.section23_award_info &amp;&amp; (stats.section23_award_info.submitted_count || stats.section23_award_info.approved_count) &amp;&amp; !stats.section23_award_info.is_completed"/>
                    <t t-set="r4_active" t-value="stats &amp;&amp; (stats.section20e_railways_total || 0) > 0"/>
                    <t t-set="steps" t-value="[
                        {'num': '1', 'label': 'Survey',  'done': sur_done,  'active': sur_active},
                        {'num': '2', 'label': 'Sec 20A', 'done': false,     'active': r2_active},
                        {'num': '3', 'label': 'Award', 'done': r3_done,   'active': r3_active},
                        {'num': '4', 'label': 'Sec 20E', 'done': false,     'active': r4_active},
                        {'num': '5', 'label': 'Voucher', 'done': pv_done,  'active': pv_active},
                        {'num': '6', 'label': 'Pay File', 'done': pay_done,  'active': pay_active}
                    ]"/>
                </t>
                <t t-elif="is_nh">
                    <t t-set="n2_active" t-value="stats &amp;&amp; (stats.section3a_nh_total || 0) > 0"/>
                    <t t-set="n3_done"   t-value="stats &amp;&amp; stats.section23_award_info &amp;&amp; stats.section23_award_info.is_completed"/>
                    <t t-set="n3_active" t-value="stats &amp;&amp; stats.section23_award_info &amp;&amp; (stats.section23_award_info.submitted_count || stats.section23_award_info.approved_count) &amp;&amp; !stats.section23_award_info.is_completed"/>
                    <t t-set="n4_active" t-value="stats &amp;&amp; (stats.section3d_nh_total || 0) > 0"/>
                    <t t-set="steps" t-value="[
                        {'num': '1', 'label': 'Survey',  'done': sur_done,  'active': sur_active},
                        {'num': '2', 'label': 'Sec 3A',  'done': false,     'active': n2_active},
                        {'num': '3', 'label': 'Award',  'done': n3_done,   'active': n3_active},
                        {'num': '4', 'label': 'Sec 3D',  'done': false,     'active': n4_active},
                        {'num': '5', 'label': 'Voucher', 'done': pv_done,  'active': pv_active},
                        {'num': '6', 'label': 'Pay File', 'done': pay_done,  'active': pay_active}
                    ]"/>
                </t>
                <t t-elif="is_cglrc">
                    <t t-set="c2_done"   t-value="stats &amp;&amp; stats.section247_1_cglrc_info &amp;&amp; stats.section247_1_cglrc_info.is_completed"/>
                    <t t-set="c2_active" t-value="stats &amp;&amp; stats.section247_1_cglrc_info &amp;&amp; stats.section247_1_cglrc_info.approved_count &amp;&amp; !stats.section247_1_cglrc_info.is_completed"/>
                    <t t-set="c3_done"   t-value="stats &amp;&amp; stats.section247_2_cglrc_info &amp;&amp; stats.section247_2_cglrc_info.is_completed"/>
                    <t t-set="c3_active" t-value="stats &amp;&amp; stats.section247_2_cglrc_info &amp;&amp; stats.section247_2_cglrc_info.approved_count &amp;&amp; !stats.section247_2_cglrc_info.is_completed"/>
                    <t t-set="c4_done"   t-value="stats &amp;&amp; stats.section247_3_cglrc_info &amp;&amp; stats.section247_3_cglrc_info.is_completed"/>
                    <t t-set="c4_active" t-value="stats &amp;&amp; stats.section247_3_cglrc_info &amp;&amp; stats.section247_3_cglrc_info.approved_count &amp;&amp; !stats.section247_3_cglrc_info.is_completed"/>
                    <t t-set="steps" t-value="[
                        {'num': '1', 'label': 'Survey',  'done': sur_done,  'active': sur_active},
                        {'num': '2', 'label': '247.1',   'done': c2_done,   'active': c2_active},
                        {'num': '3', 'label': '247.2',   'done': c3_done,   'active': c3_active},
                        {'num': '4', 'label': '247.3',   'done': c4_done,   'active': c4_active},
                        {'num': '5', 'label': 'Voucher', 'done': pv_done,  'active': pv_active},
                        {'num': '6', 'label': 'Pay File', 'done': pay_done,  'active': pay_active}
                    ]"/>
                </t>
                <t t-elif="is_coal">
                    <t t-set="c2_done"   t-value="stats &amp;&amp; stats.section4_info &amp;&amp; stats.section4_info.is_completed"/>
                    <t t-set="c2_active" t-value="stats &amp;&amp; stats.section4_info &amp;&amp; (stats.section4_info.submitted_count || stats.section4_info.approved_count) &amp;&amp; !stats.section4_info.is_completed"/>
                    <t t-set="c3_done"   t-value="stats &amp;&amp; stats.sia_info &amp;&amp; stats.sia_info.is_completed"/>
                    <t t-set="c3_active" t-value="stats &amp;&amp; stats.sia_info &amp;&amp; (stats.sia_info.submitted_count || stats.sia_info.approved_count) &amp;&amp; !stats.sia_info.is_completed"/>
                    <t t-set="c4_done"   t-value="stats &amp;&amp; stats.section8_info &amp;&amp; stats.section8_info.is_completed"/>
                    <t t-set="c4_active" t-value="stats &amp;&amp; (stats.section8_approved || stats.section8_draft) &amp;&amp; !(stats.section8_info &amp;&amp; stats.section8_info.is_completed)"/>
                    <t t-set="c5_done"   t-value="stats &amp;&amp; stats.section9_info &amp;&amp; stats.section9_info.is_completed"/>
                    <t t-set="c5_active" t-value="stats &amp;&amp; stats.section9_info &amp;&amp; (stats.section9_info.submitted_count || stats.section9_info.approved_count) &amp;&amp; !stats.section9_info.is_completed"/>
                    <t t-set="c6_done"   t-value="stats &amp;&amp; stats.section11_info &amp;&amp; stats.section11_info.is_completed"/>
                    <t t-set="c6_active" t-value="stats &amp;&amp; stats.section11_info &amp;&amp; (stats.section11_info.submitted_count || stats.section11_info.approved_count) &amp;&amp; !stats.section11_info.is_completed"/>
                    <t t-set="c7_done"   t-value="stats &amp;&amp; stats.section15_info &amp;&amp; stats.section15_info.is_completed"/>
                    <t t-set="c7_active" t-value="stats &amp;&amp; stats.section15_info &amp;&amp; (stats.section15_info.submitted_count || stats.section15_info.approved_count) &amp;&amp; !stats.section15_info.is_completed"/>
                    <t t-set="c8_done"   t-value="stats &amp;&amp; stats.section19_info &amp;&amp; stats.section19_info.is_completed"/>
                    <t t-set="c8_active" t-value="stats &amp;&amp; stats.section19_info &amp;&amp; (stats.section19_info.submitted_count || stats.section19_info.approved_count) &amp;&amp; !stats.section19_info.is_completed"/>
                    <t t-set="c9_done"   t-value="stats &amp;&amp; stats.draft_award_info &amp;&amp; stats.draft_award_info.is_completed"/>
                    <t t-set="c9_active" t-value="stats &amp;&amp; stats.draft_award_info &amp;&amp; (stats.draft_award_info.submitted_count || stats.draft_award_info.approved_count) &amp;&amp; !stats.draft_award_info.is_completed"/>
                    <t t-set="c10_active" t-value="stats &amp;&amp; (stats.section18_rr_scheme_total || 0) > 0"/>
                    <t t-set="c11_done"  t-value="stats &amp;&amp; stats.section23_award_info &amp;&amp; stats.section23_award_info.is_completed"/>
                    <t t-set="c11_active" t-value="stats &amp;&amp; stats.section23_award_info &amp;&amp; (stats.section23_award_info.submitted_count || stats.section23_award_info.approved_count) &amp;&amp; !stats.section23_award_info.is_completed"/>
                    <t t-set="steps" t-value="[
                        {'num': '1',  'label': 'Sec 4(i)',      'done': c2_done,   'active': c2_active},
                        {'num': '2',  'label': 'Sec 7(i)',      'done': c3_done,   'active': c3_active},
                        {'num': '3',  'label': 'Sec 8',         'done': c4_done,   'active': c4_active},
                        {'num': '4',  'label': 'Sec 9(i)',      'done': c5_done,   'active': c5_active},
                        {'num': '5',  'label': 'Sec 11(i)',     'done': c6_done,   'active': c6_active},
                        {'num': '6',  'label': 'Land Rec',      'done': c7_done,   'active': c7_active},
                        {'num': '7',  'label': 'DRRC',          'done': c8_done,   'active': c8_active},
                        {'num': '8',  'label': 'Asset Com.',    'done': c9_done,   'active': c9_active},
                        {'num': '9',  'label': 'Asset Survey',  'done': false,     'active': c10_active},
                        {'num': '10', 'label': 'Comp.&amp;Award', 'done': c11_done,  'active': c11_active},
                        {'num': '11', 'label': 'Struct/Award',  'done': c11_done,  'active': c11_active},
                        {'num': '12', 'label': 'Voucher',       'done': pv_done,   'active': pv_active},
                        {'num': '13', 'label': 'Pay File',      'done': pay_done,  'active': pay_active}
                    ]"/>
                </t>
                <t t-else="">
                    <t t-set="s2_done"   t-value="stats &amp;&amp; stats.sia_info &amp;&amp; stats.sia_info.is_completed"/>
                    <t t-set="s2_active" t-value="stats &amp;&amp; stats.sia_info &amp;&amp; (stats.sia_info.submitted_count || stats.sia_info.approved_count) &amp;&amp; !stats.sia_info.is_completed"/>
                    <t t-set="s3_done"   t-value="stats &amp;&amp; stats.section4_info &amp;&amp; stats.section4_info.is_completed"/>
                    <t t-set="s3_active" t-value="stats &amp;&amp; stats.section4_info &amp;&amp; (stats.section4_info.submitted_count || stats.section4_info.approved_count) &amp;&amp; !stats.section4_info.is_completed"/>
                    <t t-set="s4_done"   t-value="stats &amp;&amp; stats.expert_info &amp;&amp; stats.expert_info.is_completed"/>
                    <t t-set="s4_active" t-value="stats &amp;&amp; stats.expert_info &amp;&amp; (stats.expert_info.submitted_count || stats.expert_info.approved_count) &amp;&amp; !stats.expert_info.is_completed"/>
                    <t t-set="s5_done"   t-value="stats &amp;&amp; stats.section8_info &amp;&amp; stats.section8_info.is_completed"/>
                    <t t-set="s5_active" t-value="stats &amp;&amp; (stats.section8_approved || stats.section8_draft) &amp;&amp; !(stats.section8_info &amp;&amp; stats.section8_info.is_completed)"/>
                    <t t-set="s6_done"   t-value="stats &amp;&amp; stats.section11_info &amp;&amp; stats.section11_info.is_completed"/>
                    <t t-set="s6_active" t-value="stats &amp;&amp; stats.section11_info &amp;&amp; (stats.section11_info.submitted_count || stats.section11_info.approved_count) &amp;&amp; !stats.section11_info.is_completed"/>
                    <t t-set="s7_done"   t-value="stats &amp;&amp; stats.section15_info &amp;&amp; stats.section15_info.is_completed"/>
                    <t t-set="s7_active" t-value="stats &amp;&amp; stats.section15_info &amp;&amp; (stats.section15_info.submitted_count || stats.section15_info.approved_count) &amp;&amp; !stats.section15_info.is_completed"/>
                    <t t-set="s8_active" t-value="stats &amp;&amp; (stats.section18_rr_scheme_total || 0) > 0"/>
                    <t t-set="s9_done"   t-value="stats &amp;&amp; stats.section19_info &amp;&amp; stats.section19_info.is_completed"/>
                    <t t-set="s9_active" t-value="stats &amp;&amp; stats.section19_info &amp;&amp; (stats.section19_info.submitted_count || stats.section19_info.approved_count) &amp;&amp; !stats.section19_info.is_completed"/>
                    <t t-set="s10_done"  t-value="stats &amp;&amp; stats.draft_award_info &amp;&amp; stats.draft_award_info.is_completed"/>
                    <t t-set="s10_active" t-value="stats &amp;&amp; stats.draft_award_info &amp;&amp; (stats.draft_award_info.submitted_count || stats.draft_award_info.approved_count) &amp;&amp; !stats.draft_award_info.is_completed"/>
                    <t t-set="s11_done"  t-value="stats &amp;&amp; stats.section23_award_info &amp;&amp; stats.section23_award_info.is_completed"/>
                    <t t-set="s11_active" t-value="stats &amp;&amp; stats.section23_award_info &amp;&amp; (stats.section23_award_info.submitted_count || stats.section23_award_info.approved_count) &amp;&amp; !stats.section23_award_info.is_completed"/>
                    <t t-set="steps" t-value="[
                        {'num': '1',  'label': 'Survey',  'done': sur_done,  'active': sur_active},
                        {'num': '2',  'label': 'SIA',     'done': s2_done,   'active': s2_active},
                        {'num': '3',  'label': 'Sec 4',   'done': s3_done,   'active': s3_active},
                        {'num': '4',  'label': 'Expert',  'done': s4_done,   'active': s4_active},
                        {'num': '5',  'label': 'Sec 8',   'done': s5_done,   'active': s5_active},
                        {'num': '6',  'label': 'Sec 11',  'done': s6_done,   'active': s6_active},
                        {'num': '7',  'label': 'Sec 15',  'done': s7_done,   'active': s7_active},
                        {'num': '8',  'label': 'Sec 18',  'done': false,     'active': s8_active},
                        {'num': '9',  'label': 'Sec 19',  'done': s9_done,   'active': s9_active},
                        {'num': '10', 'label': 'Sec 21',  'done': s10_done,  'active': s10_active},
                        {'num': '11', 'label': 'Sec 23',  'done': s11_done,  'active': s11_active},
                        {'num': '12', 'label': 'Voucher', 'done': pv_done,  'active': pv_active},
                        {'num': '13', 'label': 'Pay File', 'done': pay_done,  'active': pay_active}
                    ]"/>
                </t>

                <!-- Single track renderer - no t-call, no cross-template dependency -->
                <div style="position:relative; width:100%;">
                    <div class="o_timeline_track_line" style="position:absolute; top:20px; left:0; right:0; height:4px; border-radius:2px; z-index:0;"/>
                    <div style="display:flex; align-items:flex-start; width:100%; position:relative; z-index:1;">
                        <t t-foreach="steps" t-as="step" t-key="step['num']">
                            <div style="flex:1; display:flex; flex-direction:column; align-items:center;">
                                <div style="height:44px; display:flex; align-items:center; justify-content:center;">
                                    <div t-att-class="step['active'] ? 'o_step_active_blink' : ''"
                                         t-att-style="'width:' + (step['active'] ? '42px' : '36px') + '; height:' + (step['active'] ? '42px' : '36px') + '; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:' + (steps.length > 10 ? '11px' : '13px') + '; font-weight:800; border:3px solid; ' + (step['done'] ? 'background:#38a169; border-color:#38a169; color:#fff; box-shadow:0 2px 6px rgba(56,161,105,0.4);' : step['active'] ? 'background:#fff; border-color:#ed8936; color:#ed8936;' : 'background:#edf2f7; border-color:#cbd5e0; color:#a0aec0;')">
                                        <t t-if="step['done']"><i class="fa fa-check"/></t>
                                        <t t-else=""><t t-esc="step['num']"/></t>
                                    </div>
                                </div>
                                <div t-att-style="'font-size:' + (steps.length > 10 ? '8px' : '10px') + '; text-align:center; margin-top:4px; font-weight:' + (step['active'] ? '700' : '500') + '; color:' + (step['done'] ? '#276749' : step['active'] ? '#2d3748' : '#718096') + ';'">
                                    <t t-esc="step['label']"/>
                                </div>
                                <div t-att-style="'font-size:' + (steps.length > 10 ? '7px' : '9px') + '; margin-top:2px; padding:' + (steps.length > 10 ? '0px 4px' : '1px 8px') + '; border-radius:10px; font-weight:700; ' + (step['done'] ? 'background:#f0fff4; color:#276749;' : step['active'] ? 'background:#fffaf0; color:#c05621;' : 'background:#f7fafc; color:#a0aec0;')">
                                    <t t-esc="step['done'] ? 'Done' : step['active'] ? 'Active' : 'Pending'"/>
                                </div>
                            </div>
                        </t>
                    </div>
                </div>

            </div><!-- /collapsible body -->
        </div><!-- /o_e2e_timeline_section -->
    </t>

</templates>
