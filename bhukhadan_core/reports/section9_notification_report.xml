<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_section9_notification_document">
        <t t-call="web.external_layout">
            <t t-foreach="docs" t-as="doc">
                <div class="page">
                    <h2 style="text-align:center;">Section 9 Declaration (Coal Act)</h2>
                    <p><strong>Reference:</strong> <span t-esc="doc.name"/></p>
                    <p><strong>Declaration Number:</strong> <span t-esc="doc.declaration_number or '-'"/></p>
                    <p><strong>Project:</strong> <span t-esc="doc.project_id.name or '-'"/></p>
                    <p><strong>Village:</strong> <span t-esc="doc.village_id.name or '-'"/></p>
                    <p><strong>Declaration Date:</strong> <span t-esc="doc.declaration_date or '-'"/></p>
                    <p><strong>Gazette Publication Date:</strong> <span t-esc="doc.gazette_publication_date or '-'"/></p>
                    <p><strong>Status:</strong> <span t-esc="doc.state"/></p>
                    <p style="margin-top:12px;"><strong>Notification Summary</strong></p>
                    <p t-esc="doc.notification_summary or '-'"/>
                    <p style="margin-top:12px;"><strong>Remarks</strong></p>
                    <p t-esc="doc.remarks or '-'"/>
                </div>
            </t>
        </t>
    </template>

    <record id="action_report_section9_notification" model="ir.actions.report">
        <field name="name">Section 9 Declaration</field>
        <field name="model">bhu.section9.notification</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">bhukhadan_core.report_section9_notification_document</field>
        <field name="report_file">bhukhadan_core.report_section9_notification_document</field>
        <field name="print_report_name">'Section9_%s' % (object.name or 'Declaration')</field>
        <field name="binding_model_id" ref="model_bhu_section9_notification"/>
        <field name="binding_type">report</field>
    </record>
</odoo>
