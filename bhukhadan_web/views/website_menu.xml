<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Website menu items -->
    <record id="menu_home" model="website.menu">
        <field name="name">Home</field>
        <field name="url">/</field>
        <field name="sequence">10</field>
        <field name="website_id" ref="website.default_website"/>
    </record>

    <record id="menu_contact" model="website.menu">
        <field name="name">Contact Us</field>
        <field name="url">/contact</field>
        <field name="sequence">30</field>
        <field name="website_id" ref="website.default_website"/>
    </record>

    <record id="menu_features" model="website.menu">
        <field name="name">Features</field>
        <field name="url">/features</field>
        <field name="sequence">20</field>
        <field name="website_id" ref="website.default_website"/>
    </record>

    <record id="menu_mobile_app" model="website.menu">
        <field name="name">Mobile App</field>
        <field name="url">/mobile-app</field>
        <field name="sequence">22</field>
        <field name="website_id" ref="website.default_website"/>
    </record>

    <record id="menu_cba_guide" model="website.menu">
        <field name="name">CBA Act Guide</field>
        <field name="url">/features/cba</field>
        <field name="sequence">24</field>
        <field name="website_id" ref="website.default_website"/>
    </record>

    <record id="menu_acts" model="website.menu">
        <field name="name">Acts Covered</field>
        <field name="url">/acts</field>
        <field name="sequence">25</field>
        <field name="website_id" ref="website.default_website"/>
    </record>
</odoo>
